<Window x:Class="WetrechArcnetManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wetrech ARCNET Yöneticisi"
        Height="680" Width="1020"
        MinHeight="460" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- Yenile butonu -->
        <Style x:Key="RefreshButton" TargetType="Button">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#585B70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Test butonu -->
        <Style x:Key="TestButton" TargetType="Button">
            <Setter Property="Background" Value="#89DCEB"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#A8ECF8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Kur butonu -->
        <Style x:Key="InstallButton" TargetType="Button">
            <Setter Property="Background" Value="#A6E3A1"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C3F0BE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0: Başlık -->
            <RowDefinition Height="Auto"/>   <!-- 1: Araç çubuğu -->
            <RowDefinition Height="*"/>      <!-- 2: Cihaz listesi -->
            <RowDefinition Height="Auto"/>   <!-- 3: Log paneli (başta Collapsed) -->
            <RowDefinition Height="Auto"/>   <!-- 4: Alt bilgi -->
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Wetrech ARCNET Yöneticisi"
                       FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"
                       Foreground="#89B4FA"/>
            <TextBlock Text=" — USB22-485 Cihaz Durumu"
                       FontFamily="Segoe UI" FontSize="20"
                       Foreground="#6C7086" VerticalAlignment="Bottom"/>
        </StackPanel>

        <!-- Araç çubuğu -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusBar"
                       Grid.Column="0"
                       FontFamily="Segoe UI" FontSize="11"
                       Foreground="#6C7086"
                       VerticalAlignment="Center"
                       Text="Cihazlar taranıyor…"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="KurBtn"
                        Style="{StaticResource InstallButton}"
                        Content="⬇  WinUSB Sürücüsünü Kur"
                        Margin="0,0,8,0"
                        Click="KurBtn_Click"/>
                <Button x:Name="TestBtn"
                        Style="{StaticResource TestButton}"
                        Content="▶  Seçiliyi Test Et"
                        Margin="0,0,8,0"
                        Click="TestBtn_Click"/>
                <Button x:Name="HepsiniTestBtn"
                        Style="{StaticResource TestButton}"
                        Content="▶▶  Hepsini Test Et"
                        Margin="0,0,8,0"
                        Click="HepsiniTestBtn_Click"/>
                <Button x:Name="YenileBtn"
                        Style="{StaticResource RefreshButton}"
                        Content="⟳  Yenile"
                        Click="YenileBtn_Click"/>
            </StackPanel>
        </Grid>

        <!-- Cihaz listesi -->
        <Border Grid.Row="2"
                Background="#181825"
                CornerRadius="6"
                BorderBrush="#313244"
                BorderThickness="1">
            <Grid>
                <TextBlock x:Name="BosMesaj"
                           Text="USB22 cihazı bulunamadı"
                           FontFamily="Segoe UI" FontSize="14"
                           Foreground="#6C7086"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>

                <DataGrid x:Name="CihazListesi"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#313244"
                          Background="Transparent"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#1E1E2E"
                          BorderThickness="0"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          FontFamily="Segoe UI" FontSize="12"
                          Foreground="#CDD6F4"
                          ColumnHeaderHeight="32"
                          RowHeight="34">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#181825"/>
                            <Setter Property="Foreground" Value="#89B4FA"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="BorderBrush" Value="#313244"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#313244"/>
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#313244"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <!-- Sürücü durum rozeti -->
                        <DataGridTemplateColumn Header="Durum" Width="105" SortMemberPath="Durum">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10"
                                            Background="{Binding RozetArka}"
                                            Padding="8,2"
                                            HorizontalAlignment="Left"
                                            Margin="4,0">
                                        <TextBlock Text="{Binding Durum}"
                                                   Foreground="{Binding RozetYazi}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Test sonucu rozeti (başta gizli, test sonrası güncellenir) -->
                        <DataGridTemplateColumn Header="Test" Width="115" SortMemberPath="TestMetin">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10"
                                            Background="{Binding TestArka}"
                                            Padding="8,2"
                                            HorizontalAlignment="Left"
                                            Margin="4,0"
                                            Visibility="{Binding TestGorunum}">
                                        <TextBlock Text="{Binding TestMetin}"
                                                   Foreground="{Binding TestYazi}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="PID"            Width="75"  Binding="{Binding PID}"/>
                        <DataGridTextColumn Header="Sürücü Servisi" Width="120" Binding="{Binding SurucuServisi}"/>
                        <DataGridTextColumn Header="Cihaz Tipi"     Width="195" Binding="{Binding CihazTipi}"/>
                        <DataGridTextColumn Header="Açıklama"       Width="155" Binding="{Binding Aciklama}"/>
                        <DataGridTemplateColumn Header="Instance Path" Width="*" SortMemberPath="InstancePath">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding InstancePath}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding InstancePath}"
                                               ToolTipService.ShowDuration="10000"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Log paneli — kurulum başlayınca görünür -->
        <Border Grid.Row="3"
                x:Name="LogPanel"
                Visibility="Collapsed"
                Height="180"
                Margin="0,10,0,0"
                Background="#11111B"
                CornerRadius="6"
                BorderBrush="#313244"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Kurulum Çıktısı"
                           FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                           Foreground="#89B4FA"
                           Margin="10,6,10,4"/>

                <ScrollViewer Grid.Row="1"
                              x:Name="LogScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Margin="6,0,6,6">
                    <ItemsControl x:Name="LogKutu">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Metin}"
                                           Foreground="{Binding Renk}"
                                           FontFamily="Consolas" FontSize="11"
                                           TextWrapping="NoWrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Alt bilgi -->
        <TextBlock Grid.Row="4"
                   Margin="0,10,0,0"
                   FontFamily="Segoe UI" FontSize="10"
                   Foreground="#45475A"
                   Text="VID filtresi: 0x0D0B  |  PID 0x1002/0x1003 = Operasyonel  |  PID 0xB001/0xB002 = Bootloader"/>
    </Grid>
</Window>
