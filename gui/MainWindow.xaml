<Window x:Class="WetrechArcnetManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wetrech ARCNET Yöneticisi"
        Height="720" Width="1080"
        MinHeight="500" MinWidth="780"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>

        <!-- Yenile / küçük araç butonları -->
        <Style x:Key="RefreshButton" TargetType="Button">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#585B70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Test butonları -->
        <Style x:Key="TestButton" TargetType="Button">
            <Setter Property="Background" Value="#89DCEB"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#A8ECF8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Kur butonu -->
        <Style x:Key="InstallButton" TargetType="Button">
            <Setter Property="Background" Value="#A6E3A1"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C3F0BE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tara / bağlan butonu (mauve) -->
        <Style x:Key="ScanButton" TargetType="Button">
            <Setter Property="Background" Value="#CBA6F7"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D8B4FE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Koyu TabControl -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Tab header strip -->
                            <Border Grid.Row="0" Background="#1E1E2E"
                                    BorderBrush="#313244" BorderThickness="0,0,0,1"
                                    Padding="4,4,0,0">
                                <TabPanel IsItemsHost="True" Background="Transparent"
                                          HorizontalAlignment="Left"/>
                            </Border>
                            <!-- Content area -->
                            <Border Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="0,4,4,4">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Koyu TabItem -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4,4,0,0"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontFamily="{TemplateBinding FontFamily}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45475A"/>
                                <Setter Property="Foreground" Value="#89B4FA"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3E4059"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Paragraf boşluğunu sıfırla (RichTextBox log için) -->
        <Style TargetType="Paragraph">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="LineHeight" Value="16"/>
        </Style>

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>                              <!-- 0: Başlık -->
            <RowDefinition Height="Auto"/>                              <!-- 1: Araç çubuğu -->
            <RowDefinition Height="*" MinHeight="100"/>                 <!-- 2: TabControl -->
            <RowDefinition x:Name="SplitterRowDef" Height="0"/>        <!-- 3: Sürükleme çubuğu -->
            <RowDefinition x:Name="LogRowDef"      Height="0"/>        <!-- 4: Log paneli -->
            <RowDefinition Height="Auto"/>                              <!-- 5: Alt bilgi -->
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Wetrech ARCNET Yöneticisi"
                       FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"
                       Foreground="#89B4FA"/>
            <TextBlock Text=" — USB22-485 Yönetim Paneli"
                       FontFamily="Segoe UI" FontSize="20"
                       Foreground="#6C7086" VerticalAlignment="Bottom"/>
        </StackPanel>

        <!-- Araç çubuğu -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusBar"
                       Grid.Column="0"
                       FontFamily="Segoe UI" FontSize="11"
                       Foreground="#6C7086"
                       VerticalAlignment="Center"
                       Text="Cihazlar taranıyor…"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="KurBtn"
                        Style="{StaticResource InstallButton}"
                        Content="⬇  WinUSB Sürücüsünü Kur"
                        Margin="0,0,8,0"
                        Click="KurBtn_Click"/>
                <Button x:Name="TestBtn"
                        Style="{StaticResource TestButton}"
                        Content="▶  Seçiliyi Test Et"
                        Margin="0,0,8,0"
                        Click="TestBtn_Click"/>
                <Button x:Name="HepsiniTestBtn"
                        Style="{StaticResource TestButton}"
                        Content="▶▶  Hepsini Test Et"
                        Margin="0,0,8,0"
                        Click="HepsiniTestBtn_Click"/>
                <Button x:Name="TaraBtn"
                        Style="{StaticResource ScanButton}"
                        Content="⌾  Cihazları Tara"
                        Margin="0,0,8,0"
                        Click="TaraBtn_Click"/>
                <Button x:Name="YenileBtn"
                        Style="{StaticResource RefreshButton}"
                        Content="⟳  Yenile"
                        Click="YenileBtn_Click"/>
            </StackPanel>
        </Grid>

        <!-- Ana TabControl -->
        <TabControl Grid.Row="2" x:Name="AnaTablar">

            <!-- Tab 0: WMI cihaz listesi (mevcut) -->
            <TabItem Header="WMI Cihazlar">
                <Border Background="#181825"
                        BorderBrush="#313244"
                        BorderThickness="0">
                    <Grid>
                        <TextBlock x:Name="BosMesaj"
                                   Text="USB22 cihazı bulunamadı"
                                   FontFamily="Segoe UI" FontSize="14"
                                   Foreground="#6C7086"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>

                        <DataGrid x:Name="CihazListesi"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#313244"
                                  Background="Transparent"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="#1E1E2E"
                                  BorderThickness="0"
                                  CanUserResizeRows="False"
                                  SelectionMode="Single"
                                  FontFamily="Segoe UI" FontSize="12"
                                  Foreground="#CDD6F4"
                                  ColumnHeaderHeight="32"
                                  RowHeight="34">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#181825"/>
                                    <Setter Property="Foreground" Value="#89B4FA"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="BorderBrush" Value="#313244"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Padding="{TemplateBinding Padding}"
                                                        Background="{TemplateBinding Background}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#313244"/>
                                            <Setter Property="Foreground" Value="#CDD6F4"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#313244"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Durum" Width="105" SortMemberPath="Durum">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10"
                                                    Background="{Binding RozetArka}"
                                                    Padding="8,2"
                                                    HorizontalAlignment="Left"
                                                    Margin="4,0">
                                                <TextBlock Text="{Binding Durum}"
                                                           Foreground="{Binding RozetYazi}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Test" Width="115" SortMemberPath="TestMetin">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10"
                                                    Background="{Binding TestArka}"
                                                    Padding="8,2"
                                                    HorizontalAlignment="Left"
                                                    Margin="4,0"
                                                    Visibility="{Binding TestGorunum}">
                                                <TextBlock Text="{Binding TestMetin}"
                                                           Foreground="{Binding TestYazi}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="PID"            Width="75"  Binding="{Binding PID}"/>
                                <DataGridTextColumn Header="Sürücü Servisi" Width="120" Binding="{Binding SurucuServisi}"/>
                                <DataGridTextColumn Header="Cihaz Tipi"     Width="195" Binding="{Binding CihazTipi}"/>
                                <DataGridTextColumn Header="Açıklama"       Width="155" Binding="{Binding Aciklama}"/>
                                <DataGridTemplateColumn Header="Instance Path" Width="*" SortMemberPath="InstancePath">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding InstancePath}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       ToolTip="{Binding InstancePath}"
                                                       ToolTipService.ShowDuration="10000"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ARC cihaz sekmeleri: kod tarafından eklenir (TaraBtn_Click) -->

        </TabControl>

        <!-- Sürükleme çubuğu -->
        <GridSplitter Grid.Row="3"
                      x:Name="LogSplitter"
                      Visibility="Collapsed"
                      Height="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#313244"
                      Cursor="SizeNS"
                      ResizeBehavior="PreviousAndNext"
                      Margin="0,2,0,2"/>

        <!-- Log paneli -->
        <Border Grid.Row="4"
                x:Name="LogPanel"
                Visibility="Collapsed"
                Background="#11111B"
                CornerRadius="6"
                BorderBrush="#313244"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="10,5,8,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Çıktı Günlüğü"
                                   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#89B4FA"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Kütüphane log:"
                                   FontFamily="Segoe UI" FontSize="10"
                                   Foreground="#6C7086"
                                   VerticalAlignment="Center"
                                   Margin="16,0,6,0"/>
                        <ComboBox x:Name="LogSeviyeBox"
                                  Width="70" VerticalAlignment="Center"
                                  FontFamily="Segoe UI" FontSize="10"
                                  Background="#313244" Foreground="#CDD6F4"
                                  BorderBrush="#585B70"
                                  SelectionChanged="LogSeviyeBox_SelectionChanged">
                            <ComboBoxItem Content="ERROR"/>
                            <ComboBoxItem Content="INFO" IsSelected="True"/>
                            <ComboBoxItem Content="DEBUG"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="LogKopyalaBtn"
                                Content="Kopyala"
                                Style="{StaticResource RefreshButton}"
                                FontSize="10" Padding="8,3"
                                Margin="0,0,6,0"
                                Click="LogKopyalaBtn_Click"/>
                        <Button x:Name="LogKaydetBtn"
                                Content="Kaydet…"
                                Style="{StaticResource RefreshButton}"
                                FontSize="10" Padding="8,3"
                                Click="LogKaydetBtn_Click"/>
                    </StackPanel>
                </Grid>

                <RichTextBox Grid.Row="1"
                             x:Name="LogKutu"
                             IsReadOnly="True"
                             Background="Transparent"
                             Foreground="#CDD6F4"
                             FontFamily="Consolas" FontSize="11"
                             BorderThickness="0"
                             Padding="6,0,6,6"
                             SelectionBrush="#89B4FA"
                             SelectionOpacity="0.3"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>

        <!-- Alt bilgi -->
        <TextBlock Grid.Row="5"
                   Margin="0,10,0,0"
                   FontFamily="Segoe UI" FontSize="10"
                   Foreground="#45475A"
                   Text="VID filtresi: 0x0D0B  |  PID 0x1002/0x1003 = Operasyonel  |  PID 0xB001/0xB002 = Bootloader"/>
    </Grid>
</Window>
